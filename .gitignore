# BMAD / hand-written separation (SPEC-writing-assistant).
# BMAD's footprint is confined to exactly these paths; release stripping is a
# mechanical removal of them with no judgment calls. They are also covered by
# the owner's machine-global git excludes — committed here so the separation
# holds on any clone or CI checkout, not just the owner's machine.
_bmad/
_bmad-output/
.claude/skills/bmad-*/

# BMAD spec-authoring working logs must never land under specs/ (which is
# reserved for canonical hand-written specs only).
**/.memlog.md

# Live owner identity — never commit; only the *.example.yaml template ships.
# Real identity lives in ~/.config/writing-assistant/user-config.yaml or this
# optional repo-local override (CAP-6).
config/user-config.yaml

# Live per-host-repo source declaration — created in host repos on first use;
# only the *.example.yaml template ships. Ignored defensively in case this repo
# is ever dogfooded on itself (CAP-2).
writing-sources.yaml

# Python bytecode cache (helper scripts are stdlib-only Python).
__pycache__/
*.pyc

# Local crash / scratch artifacts (e.g. Cygwin/WSL stack dumps).
*.stackdump
